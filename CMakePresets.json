{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "conf-common",
            "description": "General settings that apply to all configurations",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}"
        },
        {
            "name": "conf-unixlike-common",
            "description": "Unix-like OS settings.",
            "hidden": true,
            "inherits": "conf-common",
            "condition": {
                "type": "inList",
                "string": "${hostSystemName}",
                "list": [
                    "Linux",
                    "Darwin"
                ]
            }
        },
        {
            "name": "unixlike-hipcc-debug",
            "displayName": "hipcc Debug",
            "description": "Target Unix-like OS with hipcc, debug build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "hip"
            }
        },
        {
            "name": "unixlike-hipcc-debug-static-analysis",
            "displayName": "hipcc Debug [static-analysis]",
            "description": "Target Unix-like OS with hipcc, debug build type with static analysis.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "ON",
                "tyvi_ENABLE_CPPCHECK": "ON",
                "tyvi_BACKEND": "hip"
            }
        },
        {
            "name": "unixlike-hipcc-release",
            "displayName": "hipcc Release",
            "description": "Target Unix-like OS with hipcc, release build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "tyvi_BACKEND": "hip"
            }
        },
        {
            "name": "unixlike-g++-debug",
            "displayName": "hipcc Debug",
            "description": "Target Unix-like OS with g++, debug build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "unixlike-g++-debug-static-analysis",
            "displayName": "g++ Debug [static-analysis]",
            "description": "Target Unix-like OS with g++, debug build type with static analysis.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "ON",
                "tyvi_ENABLE_CPPCHECK": "ON",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "unixlike-g++-release",
            "displayName": "g++ Release",
            "description": "Target Unix-like OS with g++, release build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "unixlike-clang++-debug",
            "displayName": "hipcc Debug",
            "description": "Target Unix-like OS with clang++, debug build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "unixlike-clang++-debug-static-analysis",
            "displayName": "clang++ Debug [static-analysis]",
            "description": "Target Unix-like OS with clang++, debug build type with static analysis.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_CLANG_TIDY": "ON",
                "tyvi_ENABLE_CPPCHECK": "ON",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "unixlike-clang++-release",
            "displayName": "clang++ Release",
            "description": "Target Unix-like OS with clang++, release build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "macos-mpic++-debug",
            "displayName": "mpic++ Debug (macOS)",
            "description": "Target macOS with mpic++ (Homebrew clang++), cpu backend, debug build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "mpic++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "${sourceDir}/rocm-libraries/projects/rocthrust/rocthrust-install/lib/cmake/rocthrust"
            }
        }
    ],
    "testPresets": [
        {
            "name": "test-common",
            "description": "Test CMake settings that apply to all configurations",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "test-unixlike-hipcc-debug",
            "displayName": "hipcc Debug",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "unixlike-hipcc-debug"
        },
        {
            "name": "test-unixlike-hipcc-debug-static-analysis",
            "displayName": "hipcc Debug [static-analysis]",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "unixlike-hipcc-debug-static-analysis"
        },
        {
            "name": "test-unixlike-hipcc-release",
            "displayName": "hiphcc Release",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "unixlike-hipcc-release"
        }
    ]
}
